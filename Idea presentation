<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SentinelGuard XDR — Cybersecurity Architecture Briefing</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --obsidian:#050a0f;
  --obsidian2:#080f18;
  --obsidian3:#0a1520;
  --cyan:#00e5ff;
  --cyan2:#00b4cc;
  --cyan-dim:rgba(0,229,255,0.12);
  --orange:#ff6b1a;
  --orange2:#ff8c42;
  --orange-dim:rgba(255,107,26,0.12);
  --grid:rgba(0,229,255,0.06);
  --grid2:rgba(0,229,255,0.03);
  --text:#c8e6f0;
  --muted:#5a8fa0;
  --mono:'Share Tech Mono',monospace;
  --orb:'Orbitron',sans-serif;
  --raj:'Rajdhani',sans-serif;
}
 
html,body{width:100%;height:100%;background:var(--obsidian);overflow:hidden}
 
.bg-grid{
  position:fixed;inset:0;
  background-image:
    linear-gradient(var(--grid) 1px,transparent 1px),
    linear-gradient(90deg,var(--grid) 1px,transparent 1px),
    linear-gradient(var(--grid2) 1px,transparent 1px),
    linear-gradient(90deg,var(--grid2) 1px,transparent 1px);
  background-size:80px 80px,80px 80px,20px 20px,20px 20px;
  pointer-events:none;z-index:0;
}
 
.corner-tl,.corner-tr,.corner-bl,.corner-br{
  position:fixed;width:60px;height:60px;z-index:10;pointer-events:none;
}
.corner-tl{top:12px;left:12px;border-top:2px solid var(--cyan);border-left:2px solid var(--cyan)}
.corner-tr{top:12px;right:12px;border-top:2px solid var(--cyan);border-right:2px solid var(--cyan)}
.corner-bl{bottom:12px;left:12px;border-bottom:2px solid var(--orange);border-left:2px solid var(--orange)}
.corner-br{bottom:12px;right:12px;border-bottom:2px solid var(--orange);border-right:2px solid var(--orange)}
 
.topbar{
  position:fixed;top:0;left:0;right:0;height:44px;
  background:rgba(5,10,15,0.95);
  border-bottom:1px solid rgba(0,229,255,0.18);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 80px;z-index:20;
}
.topbar-brand{font-family:var(--orb);font-size:11px;color:var(--cyan);letter-spacing:3px}
.topbar-meta{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:1px}
.topbar-status{font-family:var(--mono);font-size:10px;color:var(--orange);display:flex;align-items:center;gap:8px}
.status-dot{width:6px;height:6px;border-radius:50%;background:var(--orange);animation:pulse-dot 2s infinite}
@keyframes pulse-dot{0%,100%{opacity:1;box-shadow:0 0 0 0 var(--orange)}50%{opacity:.7;box-shadow:0 0 8px 3px var(--orange)}}
 
.bottombar{
  position:fixed;bottom:0;left:0;right:0;height:44px;
  background:rgba(5,10,15,0.95);
  border-top:1px solid rgba(0,229,255,0.1);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 80px;z-index:20;
}
.page-indicator{font-family:var(--mono);font-size:10px;color:var(--muted)}
.page-counter{font-family:var(--orb);font-size:12px;color:var(--cyan)}
.progress-track{flex:1;height:2px;background:rgba(0,229,255,0.1);margin:0 24px;position:relative}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--cyan),var(--orange));transition:width .5s ease}
 
.nav-btn{
  position:fixed;top:50%;transform:translateY(-50%);
  width:48px;height:48px;border:1px solid rgba(0,229,255,0.3);
  background:rgba(0,229,255,0.05);cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  z-index:30;transition:all .2s;font-size:18px;color:var(--cyan);
  clip-path:polygon(10% 0%,100% 0%,90% 100%,0% 100%);
}
.nav-btn:hover{background:rgba(0,229,255,0.15);border-color:var(--cyan);box-shadow:0 0 20px rgba(0,229,255,0.3)}
.nav-btn.prev{left:16px}
.nav-btn.next{right:16px}
 
.slides-wrap{position:fixed;inset:44px 0 44px 0;overflow:hidden;}
.slides-track{display:flex;width:1100%;height:100%;transition:transform .6s cubic-bezier(.77,0,.175,1);}
.slide{
  width:calc(100%/11);height:100%;flex-shrink:0;
  display:flex;flex-direction:column;justify-content:center;align-items:center;
  padding:40px 80px;position:relative;overflow:hidden;
}
.slide::after{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,229,255,0.015) 2px,rgba(0,229,255,0.015) 4px);
  pointer-events:none;
}
 
.section-label{font-family:var(--mono);font-size:10px;color:var(--orange);letter-spacing:3px;text-transform:uppercase;margin-bottom:12px;}
.slide-num{font-family:var(--orb);font-size:80px;font-weight:900;position:absolute;right:80px;top:50%;transform:translateY(-50%);color:rgba(0,229,255,0.04);letter-spacing:-5px;pointer-events:none;user-select:none;}
 
.h1{font-family:var(--orb);font-size:36px;font-weight:900;color:#fff;letter-spacing:1px;line-height:1.1;margin-bottom:8px}
.h2{font-family:var(--raj);font-size:22px;font-weight:600;color:var(--cyan);letter-spacing:2px;margin-bottom:28px}
.h3{font-family:var(--raj);font-size:16px;font-weight:700;color:var(--orange);letter-spacing:2px;margin-bottom:12px;text-transform:uppercase}
.body{font-family:var(--raj);font-size:15px;color:var(--text);line-height:1.7}
.mono{font-family:var(--mono);font-size:12px;color:var(--cyan);line-height:1.6}
 
.divider{width:80px;height:2px;background:linear-gradient(90deg,var(--cyan),var(--orange));margin-bottom:28px}
 
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:48px;width:100%;max-width:960px}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:28px;width:100%;max-width:960px}
 
.card{border:1px solid rgba(0,229,255,0.15);background:rgba(0,229,255,0.03);padding:20px 24px;}
.card-orange{border-color:rgba(255,107,26,0.25);background:rgba(255,107,26,0.04)}
.card-cyan{border-color:rgba(0,229,255,0.3);background:rgba(0,229,255,0.06)}
 
.tag{display:inline-block;font-family:var(--mono);font-size:10px;padding:3px 10px;border:1px solid;letter-spacing:1px;}
.tag-cyan{color:var(--cyan);border-color:var(--cyan)}
.tag-orange{color:var(--orange);border-color:var(--orange)}
 
.code-block{
  background:rgba(0,0,0,0.6);border-left:3px solid var(--cyan);
  padding:16px 20px;font-family:var(--mono);font-size:11px;
  color:#7df1ff;line-height:1.8;overflow:hidden;
}
.code-block .kw{color:var(--orange)}
.code-block .cm{color:var(--muted)}
.code-block .str{color:#a8ff78}
.code-block .fn{color:#7df1ff}
 
.stat-big{font-family:var(--orb);font-size:48px;font-weight:900;color:var(--cyan);line-height:1}
.stat-label{font-family:var(--mono);font-size:11px;color:var(--muted);margin-top:4px;letter-spacing:2px}
 
.tech-table{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:11px}
.tech-table th{color:var(--orange);border-bottom:1px solid rgba(255,107,26,0.3);padding:8px 12px;text-align:left;letter-spacing:1px}
.tech-table td{color:var(--text);border-bottom:1px solid rgba(0,229,255,0.06);padding:8px 12px}
.tech-table tr:last-child td{border-bottom:none}
.tech-table .val{color:var(--cyan)}
 
.flow{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.flow-box{font-family:var(--mono);font-size:11px;color:var(--cyan);border:1px solid rgba(0,229,255,0.3);padding:8px 14px;white-space:nowrap;background:rgba(0,229,255,0.04);}
.flow-box.orange{color:var(--orange);border-color:rgba(255,107,26,0.4);background:rgba(255,107,26,0.05)}
.flow-arr{color:var(--cyan);font-size:14px}
 
.circles-wrap{display:flex;justify-content:center;align-items:center}
 
.log-entry{font-family:var(--mono);font-size:11px;line-height:2;padding:2px 0;border-bottom:1px solid rgba(0,229,255,0.05)}
.log-ts{color:var(--muted)}
.log-ok{color:#00ff88}
.log-warn{color:var(--orange)}
.log-alert{color:#ff3366}
 
.browser-bar{background:#1a1a2e;border-bottom:1px solid rgba(255,107,26,0.3);padding:8px 14px;display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:11px}
.browser-dot{width:10px;height:10px;border-radius:50%}
.browser-alert{background:rgba(255,51,102,0.1);border:1px solid rgba(255,51,102,0.4);padding:14px 18px}
.browser-alert-title{font-family:var(--raj);font-weight:700;font-size:15px;color:#ff3366;margin-bottom:6px}
.browser-alert-body{font-family:var(--mono);font-size:11px;color:var(--text)}
 
.hl{color:var(--cyan)}
.or{color:var(--orange)}
.gr{color:#00ff88}
 
@keyframes fadeSlideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.slide.active>*{animation:fadeSlideUp .5s ease forwards}
.slide.active>*:nth-child(2){animation-delay:.1s}
.slide.active>*:nth-child(3){animation-delay:.18s}
.slide.active>*:nth-child(4){animation-delay:.26s}
.slide.active>*:nth-child(5){animation-delay:.34s}
.slide.active>*:nth-child(6){animation-delay:.42s}
.slide.active>*:nth-child(7){animation-delay:.5s}
 
@keyframes scan{0%{transform:translateY(-100%)}100%{transform:translateY(400%)}}
.scan-line{position:absolute;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,rgba(0,229,255,0.4),transparent);animation:scan 4s linear infinite;pointer-events:none;}
 
.dash-box{border:1px solid rgba(0,229,255,0.2);background:rgba(0,229,255,0.03);padding:12px 14px}
.dash-title{font-family:var(--mono);font-size:10px;color:var(--orange);letter-spacing:2px;margin-bottom:8px}
.event-bar{display:flex;align-items:center;gap:8px;margin-bottom:5px;font-family:var(--mono);font-size:10px}
.event-bar-fill{height:14px;background:rgba(0,229,255,0.2);border-left:2px solid var(--cyan)}
.event-id{color:var(--muted);min-width:70px}
.event-count{color:var(--cyan);min-width:50px;text-align:right}
</style>
</head>
<body>
<div class="bg-grid"></div>
<div class="corner-tl"></div><div class="corner-tr"></div>
<div class="corner-bl"></div><div class="corner-br"></div>
 
<div class="topbar">
  <span class="topbar-brand">SENTINELGUARD XDR</span>
  <span class="topbar-meta">CYBERSECURITY ARCHITECTURE BRIEFING // CONFIDENTIAL</span>
  <span class="topbar-status"><span class="status-dot"></span>SYSTEMS ACTIVE</span>
</div>
 
<div class="bottombar">
  <span class="page-indicator">PAGE</span>
  <span class="page-counter" id="pageCounter">01 / 10</span>
  <div class="progress-track"><div class="progress-fill" id="progressFill" style="width:10%"></div></div>
  <span class="topbar-meta" id="slideTitle">IDENTITY & VISION</span>
</div>
 
<button class="nav-btn prev" onclick="nav(-1)">&#8249;</button>
<button class="nav-btn next" onclick="nav(1)">&#8250;</button>
 
<div class="slides-wrap">
<div class="slides-track" id="track">
 
<!-- SLIDE 1 -->
<div class="slide" id="s0">
  <div class="scan-line"></div>
  <div class="slide-num">01</div>
  <div class="section-label">// 01 — IDENTITY & VISION</div>
  <div class="h1">SentinelGuard:<br>Proactive Defense-<br>in-Depth</div>
  <div class="divider"></div>
  <div class="h2">INTERNAL CYBERSECURITY ARCHITECTURE</div>
  <div style="max-width:600px">
    <div class="body" style="margin-bottom:20px">Moving beyond perimeter security to a <span class="hl">Zero-Trust internal architecture</span> — where every layer challenges, validates, and neutralizes threats before they propagate.</div>
    <div style="display:flex;gap:16px;flex-wrap:wrap">
      <span class="tag tag-cyan">ZERO-TRUST METHODOLOGY</span>
      <span class="tag tag-orange">DEFENSE-IN-DEPTH</span>
      <span class="tag tag-cyan">AUTONOMOUS RESPONSE</span>
      <span class="tag tag-orange">REAL-TIME TELEMETRY</span>
    </div>
  </div>
  <div style="position:absolute;right:80px;bottom:80px;text-align:right">
    <svg width="200" height="200" viewBox="0 0 200 200">
      <path d="M100 10 L170 40 L170 100 Q170 155 100 185 Q30 155 30 100 L30 40 Z" fill="none" stroke="rgba(0,229,255,0.4)" stroke-width="1.5"/>
      <path d="M100 25 L158 50 L158 100 Q158 145 100 168 Q42 145 42 100 L42 50 Z" fill="rgba(0,229,255,0.05)" stroke="rgba(0,229,255,0.2)" stroke-width="1"/>
      <line x1="70" y1="75" x2="130" y2="125" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="130" y1="75" x2="70" y2="125" stroke="var(--orange)" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="100" cy="100" r="6" fill="var(--cyan)" opacity="0.8"/>
      <circle cx="100" cy="100" r="30" fill="none" stroke="rgba(0,229,255,0.2)" stroke-width="1" stroke-dasharray="4 4"/>
    </svg>
  </div>
</div>
 
<!-- SLIDE TEAM -->
<div class="slide" id="steam">
  <div class="scan-line"></div>
  <div class="slide-num">02</div>
  <div class="section-label">// 02 — PROJECT TEAM</div>
  <div class="h1">Research &<br>Development<br>Team</div>
  <div class="divider"></div>
  <div style="display:flex;flex-direction:column;gap:18px;width:100%;max-width:520px">
    <div class="card card-cyan" style="display:flex;align-items:center;gap:20px;padding:18px 24px">
      <div style="width:44px;height:44px;border:1px solid var(--cyan);display:flex;align-items:center;justify-content:center;font-family:var(--orb);font-size:13px;color:var(--cyan);flex-shrink:0">EK</div>
      <div>
        <div style="font-family:var(--raj);font-weight:700;font-size:18px;color:#fff;letter-spacing:1px">Elshad Kasimov</div>
        <div class="mono" style="font-size:10px;color:var(--muted)">// SECURITY ARCHITECT</div>
      </div>
      <div style="margin-left:auto"><span class="tag tag-cyan" style="font-size:9px">LEAD</span></div>
    </div>
    <div class="card" style="display:flex;align-items:center;gap:20px;padding:18px 24px">
      <div style="width:44px;height:44px;border:1px solid var(--orange);display:flex;align-items:center;justify-content:center;font-family:var(--orb);font-size:13px;color:var(--orange);flex-shrink:0">CA</div>
      <div>
        <div style="font-family:var(--raj);font-weight:700;font-size:18px;color:#fff;letter-spacing:1px">Chichak Abdullayeva</div>
        <div class="mono" style="font-size:10px;color:var(--muted)">// THREAT INTELLIGENCE</div>
      </div>
    </div>
    <div class="card card-orange" style="display:flex;align-items:center;gap:20px;padding:18px 24px">
      <div style="width:44px;height:44px;border:1px solid var(--orange);display:flex;align-items:center;justify-content:center;font-family:var(--orb);font-size:13px;color:var(--orange);flex-shrink:0">EM</div>
      <div>
        <div style="font-family:var(--raj);font-weight:700;font-size:18px;color:#fff;letter-spacing:1px">Emil Maharramov</div>
        <div class="mono" style="font-size:10px;color:var(--muted)">// INFRASTRUCTURE DEFENSE</div>
      </div>
    </div>
    <div class="card" style="display:flex;align-items:center;gap:20px;padding:18px 24px">
      <div style="width:44px;height:44px;border:1px solid var(--cyan);display:flex;align-items:center;justify-content:center;font-family:var(--orb);font-size:13px;color:var(--cyan);flex-shrink:0">NK</div>
      <div>
        <div style="font-family:var(--raj);font-weight:700;font-size:18px;color:#fff;letter-spacing:1px">Nihad Karimli</div>
        <div class="mono" style="font-size:10px;color:var(--muted)">// SIEM & ANALYTICS</div>
      </div>
    </div>
  </div>
  <div style="position:absolute;right:80px;top:50%;transform:translateY(-50%)">
    <svg width="180" height="280" viewBox="0 0 180 280">
      <!-- Vertical line with dots -->
      <line x1="90" y1="20" x2="90" y2="260" stroke="rgba(0,229,255,0.15)" stroke-width="1" stroke-dasharray="4 4"/>
      <circle cx="90" cy="20" r="4" fill="none" stroke="var(--cyan)" stroke-width="1"/>
      <circle cx="90" cy="90" r="4" fill="none" stroke="var(--orange)" stroke-width="1"/>
      <circle cx="90" cy="160" r="4" fill="none" stroke="var(--orange)" stroke-width="1"/>
      <circle cx="90" cy="230" r="4" fill="none" stroke="var(--cyan)" stroke-width="1"/>
      <!-- Center glow -->
      <circle cx="90" cy="140" r="40" fill="none" stroke="rgba(0,229,255,0.08)" stroke-width="20"/>
      <circle cx="90" cy="140" r="20" fill="none" stroke="rgba(0,229,255,0.12)" stroke-width="10"/>
      <text x="90" y="144" text-anchor="middle" font-family="'Orbitron'" font-size="8" fill="rgba(0,229,255,0.5)" font-weight="700">TEAM</text>
    </svg>
  </div>
</div>
 
<!-- SLIDE 2 (was 2, now 3) -->
<div class="slide" id="s1">
  <div class="scan-line"></div>
  <div class="slide-num">02</div>
  <div style="width:100%;max-width:960px;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center">
    <div>
      <div class="section-label">// 02 — STRATEGIC IMPERATIVE</div>
      <div class="h1">Why<br>SentinelGuard?</div>
      <div class="divider"></div>
      <div style="display:flex;flex-direction:column;gap:16px">
