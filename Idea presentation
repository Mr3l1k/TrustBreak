        <circle cx="160" cy="160" r="140" fill="rgba(255,107,26,0.03)"/>
        <circle cx="160" cy="160" r="100" fill="none" stroke="rgba(0,229,255,0.2)" stroke-width="1.5" stroke-dasharray="6 3"/>
        <circle cx="160" cy="160" r="100" fill="rgba(0,229,255,0.04)"/>
        <circle cx="160" cy="160" r="60" fill="rgba(0,229,255,0.08)" stroke="var(--cyan)" stroke-width="1.5"/>
        <circle cx="160" cy="160" r="18" fill="rgba(0,229,255,0.2)" stroke="var(--cyan)" stroke-width="1"/>
        <text x="160" y="20" text-anchor="middle" font-family="'Share Tech Mono'" font-size="10" fill="rgba(255,107,26,0.7)" letter-spacing="2">PERIMETER</text>
        <text x="160" y="300" text-anchor="middle" font-family="'Share Tech Mono'" font-size="10" fill="rgba(255,107,26,0.7)" letter-spacing="2">EXTERNAL ZONE</text>
        <text x="160" y="76" text-anchor="middle" font-family="'Share Tech Mono'" font-size="10" fill="rgba(0,229,255,0.7)" letter-spacing="2">ZERO-TRUST</text>
        <text x="160" y="90" text-anchor="middle" font-family="'Share Tech Mono'" font-size="10" fill="rgba(0,229,255,0.7)" letter-spacing="2">INTERNAL CORE</text>
        <circle cx="300" cy="160" r="5" fill="var(--orange)" opacity="0.5"/>
        <circle cx="20" cy="160" r="5" fill="var(--orange)" opacity="0.5"/>
        <circle cx="160" cy="300" r="5" fill="var(--orange)" opacity="0.5"/>
        <circle cx="160" cy="20" r="5" fill="var(--orange)" opacity="0.5"/>
        <text x="160" y="164" text-anchor="middle" font-family="'Orbitron'" font-size="9" fill="var(--cyan)" font-weight="700">SG XDR</text>
      </svg>
    </div>
  </div>
</div>
 
<!-- SLIDE 3 -->
<div class="slide" id="s2">
  <div class="scan-line"></div>
  <div class="slide-num">03</div>
  <div class="section-label">// 03 — SYSTEM OVERVIEW</div>
  <div class="h1">Unified Security Ecosystem</div>
  <div class="divider"></div>
  <div style="width:100%;max-width:960px">
    <div style="display:flex;align-items:center;justify-content:center;gap:6px;flex-wrap:wrap;margin-bottom:28px">
      <div class="flow-box orange">SURICATA IDS/IPS<br><span style="font-size:9px;color:var(--muted)">65K+ Rules</span></div>
      <div class="flow-arr">&#10132;</div>
      <div class="flow-box">UBUNTU LINUX<br><span style="font-size:9px;color:var(--muted)">Hardened Host</span></div>
      <div class="flow-arr">&#10132;</div>
      <div class="flow-box orange">WIN SERVER / AD<br><span style="font-size:9px;color:var(--muted)">Domain Control</span></div>
