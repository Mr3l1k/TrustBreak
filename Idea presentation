<script>
const titles=['IDENTITY & VISION','PROJECT TEAM','STRATEGIC IMPERATIVE','SYSTEM OVERVIEW','NETWORK EDGE: IPS','LINUX: PROCESS MONITOR','LINUX: TRIPWIRE & LOCKDOWN','WINDOWS TELEMETRY','ANTI-PRIVILEGE ESCALATION','XDR & USER LAYER','SPLUNK SIEM'];
let cur=0,total=11;
function update(){
  document.getElementById('track').style.transform=`translateX(-${cur*(100/11)}%)`;
  document.getElementById('pageCounter').textContent=String(cur+1).padStart(2,'0')+' / '+total;
  document.getElementById('progressFill').style.width=((cur+1)/total*100)+'%';
  document.getElementById('slideTitle').textContent=titles[cur];
  document.querySelectorAll('.slide').forEach((s,i)=>{s.classList.toggle('active',i===cur)});
}
function nav(d){cur=Math.max(0,Math.min(total-1,cur+d));update();}
document.addEventListener('keydown',e=>{
  if(e.key==='ArrowRight'||e.key==='ArrowDown') nav(1);
  if(e.key==='ArrowLeft'||e.key==='ArrowUp') nav(-1);
});
let tx=0;
document.addEventListener('touchstart',e=>{tx=e.touches[0].clientX});
document.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-tx;if(Math.abs(dx)>50) nav(dx<0?1:-1);});
update();
</script>
